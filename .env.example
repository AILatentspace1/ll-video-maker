# 必填
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith（可选，用于 trace）
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=ll-video-maker

# 模型（可覆盖默认值）
PRODUCER_MODEL=claude-sonnet-4-6
SUBAGENT_MODEL=claude-sonnet-4-6
JUDGE_MODEL=claude-haiku-4-5

# video-maker skill 路径（用于读取 reflexion 历史）
VIDEO_MAKER_SKILL_PATH=E:/workspace/orchestrator_skills/.claude/skills/video-maker

# Postgres（可选，用于持久化断点续跑）
# POSTGRES_URL=postgresql://user:pass@localhost:5432/video_maker

# HTTP 代理
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897
